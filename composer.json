{
    "name": "noisebynorthwest/php-spx-mcp",
    "type": "project",
    "license": "MIT",
    "description": "MCP server for php-spx profiler",
    "keywords": ["mcp", "profiler", "profiling", "performance", "debugging", "php", "spx"],
    "homepage": "https://github.com/NoiseByNorthwest/php-spx-mcp",
    "support": {
        "issues": "https://github.com/NoiseByNorthwest/php-spx-mcp/issues",
        "source": "https://github.com/NoiseByNorthwest/php-spx-mcp"
    },
    "authors": [
        {
            "name": "Sylvain Lassaut",
            "email": "NoiseByNorthwest@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.3",
        "ext-zlib": "*",
        "php-mcp/server": "^3.3",
        "psr/clock": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "friendsofphp/php-cs-fixer": "^3.65",
        "phpstan/phpstan": "^2.0",
        "squizlabs/php_codesniffer": "^3.10",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpstan/phpstan-deprecation-rules": "^2.0"
    },
    "scripts": {
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "phpcs": "phpcs",
        "phpstan": "phpstan analyse --memory-limit=1G"
    },
    "suggest": {
        "ext-zstd": "Required to read .txt.zst reports"
    },
    "autoload": {
        "psr-4": {
            "NoiseByNorthwest\\SpxMcp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NoiseByNorthwest\\SpxMcp\\Tests\\": "tests/"
        }
    },
    "config": {
    }
}
